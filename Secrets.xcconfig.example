// Copy this file to `Secrets.xcconfig` (git-ignored) and fill in your Supabase project values
// to activate the remote layer. Then reference it from the Genesyx target in project.yml:
//
//   targets:
//     Genesyx:
//       configFiles:
//         Debug: Secrets.xcconfig
//         Release: Secrets.xcconfig
//
// Leave blank / skip entirely for the local-only v1.

SUPABASE_URL = https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR-ANON-PUBLIC-KEY
